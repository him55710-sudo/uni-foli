# Exclude local tooling and heavyweight dev artifacts from Vercel uploads
.agents/
archive/
docs/
eval/
output/
references/
scripts/
storage/
tests/
tmp/
.pytest-*/
tmps*/
tmpt*/
.npm-cache/
.codex-temp-*/
artifacts/
brain/
build/
pdf-check/
scratch/

# Backend local/runtime artifacts
backend/.venv*/
backend/storage/
backend/.pytest_cache/
backend/__pycache__/
backend/services/api/.venv*/
backend/services/api/__pycache__/
backend/services/api/.pytest_cache/
backend/services/api/tests/

# Frontend local artifacts not needed for production build
frontend/node_modules/
frontend/dist/
frontend/output/
frontend/playwright-report/
frontend/test-results/
frontend/screenshots/
frontend/*.log
frontend/*.cpuprofile
frontend/stats.html
frontend/qa_test_output.txt
frontend/refined_qa_output.txt
frontend/ui_pattern_output.txt
frontend/test_output.txt
frontend/test_output_utf8.txt

# Keep env files out of uploads
.env
.env.*
frontend/.env
frontend/.env.*
