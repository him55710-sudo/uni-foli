APP_NAME=Polio Admissions Intelligence Backend
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
API_PREFIX=/api/v1
AUTH_ENABLED=true
AUTH_BOOTSTRAP_DEFAULT_ACCOUNTS=true
AUTH_DEFAULT_TENANT_SLUG=local-lab
AUTH_DEFAULT_TENANT_NAME=Local Lab
AUTH_DEFAULT_ADMIN_EMAIL=admin@local.polio
AUTH_DEFAULT_ADMIN_PASSWORD=ChangeMe123!
AUTH_DEFAULT_REVIEWER_EMAIL=reviewer@local.polio
AUTH_DEFAULT_REVIEWER_PASSWORD=ChangeMe123!
AUTH_DEFAULT_MEMBER_EMAIL=member@local.polio
AUTH_DEFAULT_MEMBER_PASSWORD=ChangeMe123!
AUTH_SESSION_TTL_MINUTES=720
DATABASE_URL=postgresql+psycopg://polio:polio@127.0.0.1:5432/polio
DATABASE_ECHO=false
DATABASE_AUTO_CREATE_TABLES=true
POSTGRES_ENABLE_PGVECTOR=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REDIS_URL=redis://127.0.0.1:6379/0
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=polio
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
LOCAL_OBJECT_STORE_PATH=./storage/object-store
OLLAMA_BASE_URL=http://127.0.0.1:11434
EXTRACTION_MODEL_PROVIDER=ollama
EXTRACTION_MODEL_NAME=llama3.1:8b
EXTRACTION_MODEL_API_BASE=http://127.0.0.1:11434
EXTRACTION_MODEL_API_KEY=
EXTRACTION_TIMEOUT_SECONDS=90
EXTRACTION_MAX_RETRIES=2
EXTRACTION_RETRY_BACKOFF_SECONDS=1.5
EXTRACTION_BATCH_SIZE=4
EXTRACTION_PROMPT_KEY=claim_extraction_v2
VECTOR_DIMENSIONS=1536
RETRIEVAL_CANDIDATE_POOL_SIZE=40
RETRIEVAL_LEXICAL_WEIGHT=0.34
RETRIEVAL_VECTOR_WEIGHT=0.26
RETRIEVAL_TRUST_WEIGHT=0.14
RETRIEVAL_QUALITY_WEIGHT=0.10
RETRIEVAL_FRESHNESS_WEIGHT=0.08
RETRIEVAL_OFFICIAL_DOCUMENT_BOOST=0.08
RETRIEVAL_CURRENT_CYCLE_BOOST=0.08
RETRIEVAL_APPROVED_CLAIM_BOOST=0.08
RETRIEVAL_DIRECT_RULE_BOOST=0.04
RETRIEVAL_CONFLICT_PENALTY_WEIGHT=0.18
RETRIEVAL_STALE_PENALTY_WEIGHT=0.08
RETRIEVAL_LOW_TRUST_PENALTY_WEIGHT=0.10
RETRIEVAL_FRESHNESS_THRESHOLD=0.55
RETRIEVAL_EMBEDDING_PROVIDER=hashing
RETRIEVAL_EMBEDDING_MODEL=hashing-1536
RETRIEVAL_EMBEDDING_API_BASE=
RETRIEVAL_EMBEDDING_API_KEY=
RETRIEVAL_RERANKER_ENABLED=false
RETRIEVAL_RERANKER_PROVIDER=none
RETRIEVAL_RERANKER_MODEL=
STALE_AFTER_DAYS=180
DEFAULT_OWNER_KEY=local-dev
CRAWLER_USER_AGENT=PolioAdmissionsCrawler/0.1
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_MAX_PAGES_PER_JOB=25
CRAWLER_RESPECT_ROBOTS_BY_DEFAULT=true
DOCLING_ENABLED=true
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=
PRIVACY_DEFAULT_MASKING_MODE=mask_for_index
PRIVACY_LOG_MASKING_ENABLED=true
STUDENT_DATA_RETENTION_DAYS=365
PRESIDIO_ENABLED=true
PRESIDIO_HELPER_PYTHON=
PRESIDIO_HELPER_TIMEOUT_SECONDS=12
PRESIDIO_ALLOW_REGEX_FALLBACK=true
