# Must point to the backend API origin (not the frontend origin) in deployed environments.
VITE_API_URL="http://localhost:8000"
VITE_SYNC_API_JOBS="false"

# Do not put GEMINI_API_KEY or any server secrets in frontend env files.

# Optional: enable Firebase Auth/Firestore. Guest mode is auto-enabled only in local dev.
# To allow guest mode in a non-dev environment, set VITE_ALLOW_GUEST_MODE="true" explicitly.
VITE_ALLOW_GUEST_MODE="false"
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
