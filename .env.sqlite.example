APP_NAME=polio Backend
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./storage/runtime/polio.db
DATABASE_ECHO=false
DATABASE_AUTO_CREATE_TABLES=true
POSTGRES_ENABLE_PGVECTOR=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_INLINE_RENDER=true
AUTO_INGEST_UPLOADS=true
UPLOAD_CHUNK_SIZE_CHARS=1200
UPLOAD_CHUNK_OVERLAP_CHARS=180
VECTOR_DIMENSIONS=1536
